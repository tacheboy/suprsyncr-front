# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# S3 / LocalStack — for displaying images uploaded by backend
NEXT_PUBLIC_S3_ENDPOINT=http://localhost:4566
NEXT_PUBLIC_S3_BUCKET=suprsyncr-product-images

# Production values (use in .env.production.local)
# NEXT_PUBLIC_API_URL=https://api.suprsyncr.com
# NEXT_PUBLIC_S3_ENDPOINT=https://cdn.suprsyncr.com
